/* mfe-catalog remote — app build tsconfig. Extends the workspace base
   (inherits strict mode + the @mesell/* path aliases). */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/mfe-catalog",
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "../../libs/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "../../libs/**/*.spec.ts"
  ]
}
