# k8s/svc-image/secrets.yaml.example
# ===========================================================================
# svc-image — Sub-Plan C (image extraction), INFRA deliverable I7 (+ I8 Valkey
# budget-brake access + I9 Celery queue wiring documented inline).
#
# TEMPLATE ONLY — DO NOT commit a populated copy (playbook §0; no secret in git).
#
# The svc-image Secret is named `svc-image-secrets` in the `dev` namespace.
# Both svc-image Deployments (api + worker) consume it via
# `envFrom: secretRef: { name: svc-image-secrets }` (see deployment.yaml).
#
# Authority: handoff_msC_infra.md §1 I7/I8/I9 + spec_msC_backend_EXECUTION.md
# §0.5/§1.B1 (trimmed Settings) + MASTER_PLAN §5.D ("each service has its own
# trimmed Settings with ONLY the env vars it needs").
#
# ── WHAT svc-image NEEDS (and ONLY this) ────────────────────────────────────
#   - DATABASE_URL   — points at the `image` schema (role=image_user).
#   - VALKEY_URL     — cache + the SHARED ai_ops budget brake (DB 0). See I8.
#   - CELERY_BROKER_URL / CELERY_RESULT_BACKEND — broker DB 1 / results DB 2. See I9.
#   - JWT_SECRET     — LOCAL JWT verification (D7/A2: every service validates JWT
#                      locally via vendored core/auth.py; svc-image does NOT call
#                      iam-svc per token). Shared HS256 secret from SM `jwt-secret`.
#   - GEMINI_API_KEY — *** image IS AI-consuming *** (ai_ops watermark.v1; tasks.py
#                      call_gemini(ctx,"watermark.v1",...)). From SM `gemini-api-key`.
#   - LANGFUSE_SECRET_KEY — AI tracing. From SM `langfuse-secret-key` (already
#                      populated per §22 audit; verified ENABLED 2026-06-13).
#     (LANGFUSE_PUBLIC_KEY + LANGFUSE_HOST come from the shared ConfigMap meesell-config.)
#   - GCS_* (bucket + project + image bucket; mostly non-secret, from ConfigMap; the
#     image bucket key GCS_BUCKET_IMAGES is the one svc-image actually writes to).
#   - APP_ENV        — Pydantic Settings Literal {development|staging|production}.
#
# ── WHAT svc-image MUST NOT RECEIVE (handoff §1 I7) ─────────────────────────
#   NO MSG91_AUTH_KEY / MSG91_TEMPLATE_ID  (no SMS/OTP — that's iam-svc)
#   NO RAZORPAY_* / RAZORPAY_WEBHOOK_SECRET (no payment — that's iam-svc/billing)
#   NO REFRESH_TOKEN_PEPPER* / AUDIT_PII_SALT  (auth/pii concerns — iam-svc owns)
#   This trimming is the §5.D blast-radius win: a compromised svc-image pod cannot
#   read the SMS key or the Razorpay secret. (It CAN read the Gemini key — that is
#   intrinsic to its AI workload and is the accepted, scoped exposure.)
#
# ── DATABASE_URL — schema-scoped (MASTER_PLAN §2.D / §2.E) ───────────────────
#   Role = image_user (created by schema-role.sql, I5). search_path pins `image`
#   first then `public` (so the app sees its own product_images AND public.audit_events).
#   asyncpg passes server options via the URL `options` query param, URL-encoded:
#     ?options=-csearch_path%3Dimage,public
#   Host = postgres.dev.svc.cluster.local:5432 (the shared StatefulSet — V1.5 shares
#   one Postgres; the PgBouncer DATABASE_URL flip is a SEPARATE founder-gated step,
#   NOT in Sub-Plan C).
#   Password = the image_user password set out-of-band from SM (see I5) — the SAME
#   value used in ALTER ROLE image_user WITH PASSWORD. URL-encode any +,/,@ in the
#   password with urllib.parse.quote(pw, safe='') (MEMORY 2026-06-09 PG/Redis URL
#   parsing lesson — base64 passwords break URL parsing if embedded raw).
#
# ── I8 — VALKEY budget-brake access (SHARED instance, DB 0, UN-prefixed keys) ──
#   *** svc-image's VALKEY_URL MUST hit the SAME Valkey instance as the monolith +
#   other AI services *** so the GLOBAL ₹500/day budget brake (D6) stays coordinated.
#   The vendored ai_ops budget_cap reads/writes DB 0 keys, UN-prefixed (global):
#     ai:cost:daily:{YYYY-MM-DD}        (committed spend)
#     ai:cost:pending:{YYYY-MM-DD}      (reserved-but-not-committed)
#     ai:budget:reservation:{id}        (per-reservation INR)
#   These are NOT prefixed with `svc-image:` — they are intentionally global so a
#   cross-service integration test can assert ai:cost:daily coherence. DB layout:
#   DB 0 = budget + sessions + OTP + rate-limits; DB 1 broker; DB 2 results; DB 3 cache.
#   Infra side is JUST the URL pointing at valkey.dev.svc.cluster.local — the
#   un-prefixed-ness is enforced in the vendored ai_ops code, not here.
#
# ── I9 — Celery queue wiring (DEDICATED `svc-image` queue) ──────────────────
#   svc-image's celery_app: broker = VALKEY DB 1, results = DB 2, global_keyprefix
#   `svc-image:`, task_default_queue `svc-image` (deployment.yaml `-Q svc-image`).
#   This is DISJOINT from the monolith's `image-tasks` queue (PR #143) and the
#   default `celery` queue — the `svc-image:` keyprefix guarantees no broker-key
#   collision. One-off cutover backfill of in-flight image.precheck state is row-
#   level idempotent (re-run safe) — handled at cutover, not here.
#
# Populate from GCP Secret Manager (project=project-1f5cbf72-2820-4cdb-949):
#   JWT_SECRET           ← SM `jwt-secret`           (gcloud secrets versions access latest --secret=jwt-secret)
#   GEMINI_API_KEY       ← SM `gemini-api-key`       (verified ENABLED v1, 2026-06-13)
#   LANGFUSE_SECRET_KEY  ← SM `langfuse-secret-key`  (verified ENABLED v1, 2026-06-13)
#   image_user password  ← SM `dev-image-db-password` (NEW SM secret — founder to
#                            create at bootstrap; SAME value used in I5 ALTER ROLE)
#                            ⚠ INTER-LEAD/founder: this is the one new SM secret
#                            Sub-Plan C needs. It is a per-service DB password, NOT
#                            a new IAM grant — within the §4 ceiling. Founder creates
#                            the SM container + version; infra composes it into
#                            DATABASE_URL. (Mirrors svc-export's dev-export-db-password.)
# ===========================================================================
apiVersion: v1
kind: Secret
metadata:
  name: svc-image-secrets
  namespace: dev
type: Opaque
stringData:
  # --- Database (schema-scoped to `image`, role image_user) ---
  DATABASE_URL: "postgresql+asyncpg://image_user:REPLACE-ME@postgres.dev.svc.cluster.local:5432/meesell?options=-csearch_path%3Dimage,public"

  # --- Valkey (SHARED instance; DB 0 budget brake; broker DB 1 / result DB 2) ---
  # I8: DB 0 carries the UN-prefixed global ai:cost:* / ai:budget:* keys — MUST be
  # the same Valkey as the monolith for the ₹500/day brake to stay coordinated.
  VALKEY_URL: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/0"
  CELERY_BROKER_URL: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/1"
  CELERY_RESULT_BACKEND: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/2"

  # --- JWT (LOCAL verification per D7/A2; shared HS256 secret from SM jwt-secret) ---
  JWT_SECRET: "REPLACE-ME-FROM-SM-jwt-secret"

  # --- AI (image IS AI-consuming — watermark.v1) ---
  GEMINI_API_KEY: "REPLACE-ME-FROM-SM-gemini-api-key"
  LANGFUSE_SECRET_KEY: "REPLACE-ME-FROM-SM-langfuse-secret-key"
  # LANGFUSE_PUBLIC_KEY + LANGFUSE_HOST come from the shared ConfigMap meesell-config.

  # --- App env (Pydantic Literal: development|staging|production) ---
  # dev namespace ⇒ "development" (MEMORY: NEVER "dev"; the Literal type rejects it).
  APP_ENV: "development"

  # --- GCS (keyless auth — no key.json; org policy forbids SA JSON keys) ---
  # Most GCS values come from meesell-config; the image bucket is the one svc-image
  # writes to. GCS_BUCKET_IMAGES is in the shared ConfigMap (meesell-images, live
  # since 2026-06-12) — listed here for completeness; do NOT duplicate-set if the
  # ConfigMap already provides it (envFrom ConfigMap is applied first, Secret
  # overrides — keep the value identical or omit here to avoid drift).
  # GCS_BUCKET_IMAGES: "meesell-images"   # from meesell-config — DO NOT redefine here.
  # NO GOOGLE_APPLICATION_CREDENTIALS — keyless via GCE metadata server (I6).

  # --- DELIBERATELY ABSENT (handoff §1 I7): MSG91_AUTH_KEY, MSG91_TEMPLATE_ID,
  #     RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET, RAZORPAY_WEBHOOK_SECRET,
  #     REFRESH_TOKEN_PEPPER*, AUDIT_PII_SALT. ---
