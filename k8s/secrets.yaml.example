# Template only — DO NOT commit a populated copy of this file.
#
# Per BACKEND_ARCHITECTURE.md §20.C, the application Secret is named
# `backend-secrets` in the `dev` namespace. The API and worker Deployments
# consume it via `envFrom: secretRef: { name: backend-secrets }`.
#
# LEGACY NOTE: pre-§20 manifests used the name `meesell-secrets`. That name is
# retained ONLY as a backwards-compat alias in old docs; new Deployment specs
# reference `backend-secrets`. If a `meesell-secrets` Secret still exists in the
# cluster, it may be left in place (no deletes without founder approval) but is
# no longer the source of truth.
#
# IN-CLUSTER DATASTORE SECRETS ARE SEPARATE: the postgres and valkey
# StatefulSets are Terraform-managed and read their own dedicated k8s Secrets
# (`postgres-credentials`, `valkey-credentials`) created during Day-1 bootstrap
# (playbook §5.1 / §6.1). They do NOT read backend-secrets. The POSTGRES_PASSWORD
# / DATABASE_URL / VALKEY_URL entries below are for the *application* containers
# to dial those datastores, and the password values MUST match what the
# StatefulSets were created with.
#
# Authoritative source for values: GCP Secret Manager
# (project=project-1f5cbf72-2820-4cdb-949). Local backups under
# ~/.meesell-secrets/ (chmod 700 dir, chmod 600 files).
#
# Production injection pattern (per §20.C): app pods use `envFrom: secretRef:`,
# NOT inline `valueFrom: secretKeyRef:` for individual fields. This k8s Secret is
# populated from Secret Manager either manually during bootstrap OR via
# external-secrets-operator (deferred to V1.5).

apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: dev
type: Opaque
stringData:
  # --- Database / cache (composed in-cluster URLs; passwords from Secret Manager) ---
  # POSTGRES_PASSWORD must equal the value the postgres StatefulSet was created
  # with (local backup: ~/.meesell-secrets/dev-postgres-password).
  POSTGRES_PASSWORD: "REPLACE-ME"
  DATABASE_URL: "postgresql+asyncpg://meesell:REPLACE-ME@postgres.dev.svc.cluster.local:5432/meesell"
  VALKEY_URL: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/0"
  CELERY_BROKER_URL: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/1"
  CELERY_RESULT_BACKEND: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/2"

  # --- Live Secret Manager refs (Phase A populated — 7) ---
  GEMINI_API_KEY: "REPLACE-ME"        # SM: gemini-api-key
  MSG91_AUTH_KEY: "REPLACE-ME"        # SM: msg91-auth-key
  MSG91_TEMPLATE_ID: "REPLACE-ME"     # SM: msg91-template-id
  JWT_SECRET: "REPLACE-ME-WITH-LONG-RANDOM-STRING"  # SM: jwt-secret
  RAZORPAY_KEY_ID: "REPLACE-ME"       # SM: razorpay-key-id
  RAZORPAY_KEY_SECRET: "REPLACE-ME"   # SM: razorpay-key-secret
  AUDIT_PII_SALT: "REPLACE-ME"        # SM: audit-pii-salt

  # --- §20.C Secret Manager refs (status as of 2026-06-08) ---
  # refresh-token-pepper: POPULATED — SM version 1 LIVE (openssl rand -hex 32).
  #   Retrieve: gcloud secrets versions access latest --secret=refresh-token-pepper \
  #             --project=project-1f5cbf72-2820-4cdb-949
  REFRESH_TOKEN_PEPPER: "REPLACE-ME"     # SM: refresh-token-pepper (LIVE — fetch from SM)
  #
  # razorpay-webhook-secret: SM CONTAINER CREATED, NO VERSION YET — FOUNDER ACTION REQUIRED.
  #   1. Go to https://dashboard.razorpay.com/app/webhooks
  #   2. Create/view the webhook for mesell.xyz, copy the signing secret.
  #   3. Run:
  #      printf '%s' 'WEBHOOK_SECRET_HERE' | \
  #        gcloud secrets versions add razorpay-webhook-secret \
  #          --project=project-1f5cbf72-2820-4cdb-949 --data-file=-
  RAZORPAY_WEBHOOK_SECRET: "REPLACE-ME"  # SM: razorpay-webhook-secret (PENDING — founder)
  #
  # langfuse-secret-key: SM CONTAINER CREATED, NO VERSION YET — FOUNDER ACTION REQUIRED.
  #   1. Create an account at https://cloud.langfuse.com
  #   2. Settings -> API Keys -> copy the Secret Key (sk-lf-...) and Public Key (pk-lf-...).
  #   3. Run:
  #      printf '%s' 'sk-lf-...' | \
  #        gcloud secrets versions add langfuse-secret-key \
  #          --project=project-1f5cbf72-2820-4cdb-949 --data-file=-
  #   4. Put the PUBLIC key into k8s/config.yaml LANGFUSE_PUBLIC_KEY (it is non-secret).
  LANGFUSE_SECRET_KEY: "REPLACE-ME"      # SM: langfuse-secret-key (PENDING — founder + LangFuse account)

  # --- GCS (single-bucket model per Phase A SSOT) ---
  # Non-secret values; duplicated in config.yaml for the app. Kept here only if a
  # consumer reads them from the Secret. Authoritative copy is config.yaml.
  GCS_BUCKET: "meesell-prod-assets"
  GCS_PROJECT_ID: "project-1f5cbf72-2820-4cdb-949"
