apiVersion: v1
kind: Secret
metadata:
  name: meesell-secrets
  namespace: meesell
type: Opaque
stringData:
  POSTGRES_PASSWORD: "REPLACE-ME"
  DATABASE_URL: "postgresql+asyncpg://meesell:REPLACE-ME@postgres:5432/meesell"
  VALKEY_URL: "redis://valkey:6379/0"
  CELERY_BROKER_URL: "redis://valkey:6379/1"
  CELERY_RESULT_BACKEND: "redis://valkey:6379/2"
  GEMINI_API_KEY: "REPLACE-ME"
  GCS_BUCKET: "meesell-prod"
  GCS_PROJECT_ID: "REPLACE-ME"
  MSG91_AUTH_KEY: "REPLACE-ME"
  MSG91_TEMPLATE_ID: "REPLACE-ME"
  JWT_SECRET: "REPLACE-ME-WITH-LONG-RANDOM-STRING"
  RAZORPAY_KEY_ID: "REPLACE-ME"
  RAZORPAY_KEY_SECRET: "REPLACE-ME"
