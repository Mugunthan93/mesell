# k8s/pgbouncer-userlist.secret.yaml.example
# ============================================================================
# TEMPLATE ONLY — DO NOT commit a populated copy of this file (playbook §10).
# ============================================================================
# This Secret holds PgBouncer's `userlist.txt` — the credential file PgBouncer
# reads to authenticate clients (auth_type=md5 in pgbouncer.ini). It is mounted
# at /etc/pgbouncer/userlist.txt by k8s/pgbouncer.yaml.
#
# FORMAT of userlist.txt (one line per role):
#   "username" "md5<hex>"
# where md5<hex> = "md5" + md5( password + username ).
#
# The password MUST be the live `meesell` Postgres password — the same value the
# postgres StatefulSet was created with (k8s Secret `postgres-credentials`,
# key `password`; local backup ~/.meesell-secrets/dev-postgres-password).
# If they differ, PgBouncer authenticates clients fine but FAILS to open the
# real backend connection to Postgres.
#
# ---------------------------------------------------------------------------
# POPULATE PROCEDURE (run from the founder laptop with cluster access; the
# password NEVER appears in a committed file, a log, or chat — playbook §10):
# ---------------------------------------------------------------------------
#
#   # 1. Source the LIVE postgres password from the in-cluster Secret (SSOT).
#   #    (Equivalent: cat ~/.meesell-secrets/dev-postgres-password)
#   PGPW="$(kubectl -n dev get secret postgres-credentials \
#            -o jsonpath='{.data.password}' | base64 -d)"
#
#   # 2. Compute the md5 userlist hash for role `meesell`.
#   #    PgBouncer wants: md5 + md5(password || username)
#   HASH="md5$(printf '%s%s' "$PGPW" "meesell" | md5sum | cut -d' ' -f1)"
#
#   # 3. Build userlist.txt content and create/refresh the Secret idempotently.
#   printf '"meesell" "%s"\n' "$HASH" > /tmp/userlist.txt
#   kubectl -n dev create secret generic pgbouncer-userlist \
#     --from-file=userlist.txt=/tmp/userlist.txt \
#     --dry-run=client -o yaml | kubectl apply -f -
#   shred -u /tmp/userlist.txt 2>/dev/null || rm -f /tmp/userlist.txt
#   unset PGPW HASH
#
#   # 4. (After pgbouncer.yaml is applied) restart the pooler so it re-reads the
#   #    userlist, then validate (see PR runbook "Verification"):
#   kubectl -n dev rollout restart deployment/pgbouncer
#   kubectl -n dev exec deploy/pgbouncer -- \
#     psql "postgresql://meesell:$PGPW@127.0.0.1:6432/pgbouncer" -c "SHOW POOLS;"
#
# ---------------------------------------------------------------------------
# The YAML below is a NON-FUNCTIONAL placeholder showing the Secret shape. Do
# NOT `kubectl apply` it with REPLACE-ME in place — use the procedure above,
# which never writes a real hash to a committed file.
# ---------------------------------------------------------------------------
apiVersion: v1
kind: Secret
metadata:
  name: pgbouncer-userlist
  namespace: dev
  labels:
    app: pgbouncer
type: Opaque
stringData:
  # Replace via the POPULATE PROCEDURE above — never commit a real md5 hash.
  userlist.txt: |
    "meesell" "md5REPLACE-ME-COMPUTED-VIA-POPULATE-PROCEDURE"
