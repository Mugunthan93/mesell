# k8s/svc-dashboard/secrets.yaml.example
# ===========================================================================
# svc-dashboard — Sub-Plan B (dashboard extraction), INFRA deliverable I7.
#
# TEMPLATE ONLY — DO NOT commit a populated copy (playbook §0; no secret in git).
#
# The svc-dashboard Secret is named `svc-dashboard-secrets` in the `dev`
# namespace. The single svc-dashboard-api Deployment consumes it via
# `envFrom: secretRef: { name: svc-dashboard-secrets }` (see deployment.yaml).
#
# Authority: handoff_msB_infra.md §1 I7 + SUB_PLAN_0B §0.8 "shared/{database,
# config,valkey}.py TRIMMED Settings" + MASTER_PLAN §5.D ("each service has its
# own trimmed Settings with ONLY the env vars it needs").
#
# ── WHAT svc-dashboard NEEDS (and ONLY this) ────────────────────────────────
#   - DATABASE_URL — NO owned schema (§0.8): plain `public` search_path. Needed
#                    only for the vendored middleware chain + Depends(get_db)
#                    session wiring + the INERT audit_mw path. Query volume ~0.
#   - VALKEY_URL   — rate_limit DB 0 (the @rate_limit(scope="dashboard_list",
#                    limit=600, window=3600) decorator, router.py:86) + the inert
#                    audit path. Shared Valkey, `svc-dashboard:` key prefix in app.
#   - JWT_SECRET   — LOCAL JWT verification (D7/A2: every service validates JWT
#                    locally via vendored core/auth.py; dashboard does NOT call
#                    iam-svc per token). Shared HS256 secret from SM `jwt-secret`.
#
# ── WHAT svc-dashboard MUST NOT RECEIVE (handoff §1 I7 — pure read, no side-FX) ─
#   NO GEMINI_API_KEY        (no AI — dashboard is a read-only composition GET)
#   NO LANGFUSE_SECRET_KEY    (no AI tracing)
#   NO MSG91_AUTH_KEY / MSG91_TEMPLATE_ID  (no SMS/OTP — that's iam-svc)
#   NO RAZORPAY_* / RAZORPAY_WEBHOOK_SECRET (no payment — that's iam-svc/billing)
#   NO GCS_* / GOOGLE_APPLICATION_CREDENTIALS (no storage — dashboard touches NO
#                            GCS at all; contrast svc-export which DOES carry GCS_*.
#                            This is the I6 SKIP made concrete — see report.)
#   NO REFRESH_TOKEN_PEPPER* / AUDIT_PII_SALT  (auth/pii concerns — iam-svc owns)
#   This trimming is the §5.D blast-radius win: a compromised svc-dashboard pod
#   cannot read the Gemini key, the SMS key, the Razorpay secret, OR any GCS creds.
#   svc-dashboard has the SMALLEST secret surface of any extracted service.
#
# ── DATABASE_URL — NO schema override (contrast svc-export) ──────────────────
#   Role = dashboard_user (created by audit-grant.sql, I5). UNLIKE svc-export,
#   there is NO `?options=-csearch_path%3D...` — dashboard owns no schema, so the
#   default `public` search_path is correct (it only needs public for the inert
#   audit path). Host = postgres.dev.svc.cluster.local:5432 (the shared
#   StatefulSet — V1.5 shares one Postgres; PgBouncer/MS-DB-4 NOT in Sub-Plan B,
#   and dashboard's ~2-3 conn pool makes it a non-concern anyway, §0.8 / I9).
#   Password = the dashboard_user password set out-of-band from SM (see I5) — the
#   SAME value used in ALTER ROLE dashboard_user WITH PASSWORD. URL-encode any
#   +,/,@ in the password with urllib.parse.quote(pw, safe='') (MEMORY 2026-06-09
#   Redis/PG URL-parsing lesson — base64 passwords break URL parsing raw).
#
# ── POOL SIZE (deliverable I9 — dashboard's pool is the SMALLEST) ────────────
#   The pool size lives in the backend lane's vendored shared/database.py
#   (engine create_async_engine pool_size=2, max_overflow=1 — §0.8 "2-3 conns").
#   max_connections=200 + PgBouncer are ALREADY LIVE on dev (MS-0, #181/#192) —
#   NOT re-applied here (I9 is a documentation/right-size note, see report).
#   dashboard's tiny pool means even the monolith+all-services connection sum
#   stays well under 200. NO new max_connections change for Sub-Plan B.
#
# Populate from GCP Secret Manager (project=project-1f5cbf72-2820-4cdb-949):
#   JWT_SECRET              ← SM `jwt-secret`  (gcloud secrets versions access latest --secret=jwt-secret)
#   dashboard_user password ← SM `dev-dashboard-db-password` (NEW SM secret —
#                             founder to create at bootstrap; SAME value used in
#                             the I5 ALTER ROLE)
#                             ⚠ INTER-LEAD: this is the one new SM secret Sub-Plan
#                             B needs. It is a per-service DB password, NOT a new
#                             IAM grant — within the §4 ceiling. Founder creates
#                             the SM container + version; infra composes it into
#                             DATABASE_URL. (Mirrors svc-export's
#                             `dev-export-db-password`.)
#   VALKEY password         ← the existing dev Valkey password (SM/dev creds, same
#                             value the monolith uses; shared instance).
# ===========================================================================
apiVersion: v1
kind: Secret
metadata:
  name: svc-dashboard-secrets
  namespace: dev
type: Opaque
stringData:
  # --- Database (NO owned schema; role dashboard_user; default public search_path) ---
  DATABASE_URL: "postgresql+asyncpg://dashboard_user:REPLACE-ME@postgres.dev.svc.cluster.local:5432/meesell"

  # --- Valkey (shared instance; rate_limit DB 0; svc-dashboard: key prefix in app) ---
  # NO CELERY_BROKER_URL / CELERY_RESULT_BACKEND — dashboard has NO Celery (§0.6).
  VALKEY_URL: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/0"

  # --- JWT (LOCAL verification per D7/A2; shared HS256 secret from SM jwt-secret) ---
  JWT_SECRET: "REPLACE-ME-FROM-SM-jwt-secret"

  # --- DELIBERATELY ABSENT (handoff §1 I7): GEMINI_API_KEY, LANGFUSE_SECRET_KEY,
  #     MSG91_AUTH_KEY, MSG91_TEMPLATE_ID, RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET,
  #     RAZORPAY_WEBHOOK_SECRET, REFRESH_TOKEN_PEPPER*, AUDIT_PII_SALT,
  #     GCS_BUCKET / GCS_PROJECT_ID / GOOGLE_APPLICATION_CREDENTIALS (no GCS — I6 skip).
  #     APP_ENV + FEATURE_TRACKING_DASHBOARD_ENABLED live in the ConfigMap (I8),
  #     NOT here (they are non-secret). ---
