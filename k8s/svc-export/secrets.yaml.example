# k8s/svc-export/secrets.yaml.example
# ===========================================================================
# svc-export — Sub-Plan A (export extraction), INFRA deliverable I7.
#
# TEMPLATE ONLY — DO NOT commit a populated copy (playbook §0; no secret in git).
#
# The svc-export Secret is named `svc-export-secrets` in the `dev` namespace.
# Both svc-export Deployments (api + worker) consume it via
# `envFrom: secretRef: { name: svc-export-secrets }` (see deployment.yaml).
#
# Authority: handoff_msA_infra.md §1 I7 + spec_msA_backend §3.A + MASTER_PLAN §5.D
# ("each service has its own trimmed Settings with ONLY the env vars it needs").
#
# ── WHAT svc-export NEEDS (and ONLY this) ───────────────────────────────────
#   - DATABASE_URL   — points at the `export` schema (role=export_user).
#   - VALKEY_URL     — Celery broker/result + any cache; shared Valkey, prefixed.
#   - JWT_SECRET     — LOCAL JWT verification (D7/A2: every service validates JWT
#                      locally via vendored core/auth.py; svc-export does NOT call
#                      iam-svc per token). Shared HS256 secret from SM `jwt-secret`.
#   - GCS_* (bucket + project; non-secret but consumed here for completeness).
#   - APP_ENV        — Pydantic Settings Literal {development|staging|production}.
#
# ── WHAT svc-export MUST NOT RECEIVE (handoff §1 I7 — export is deterministic) ──
#   NO GEMINI_API_KEY        (no AI — export is deterministic XLSX assembly)
#   NO LANGFUSE_SECRET_KEY    (no AI tracing)
#   NO MSG91_AUTH_KEY / MSG91_TEMPLATE_ID  (no SMS/OTP — that's iam-svc)
#   NO RAZORPAY_* / RAZORPAY_WEBHOOK_SECRET (no payment — that's iam-svc/billing)
#   NO REFRESH_TOKEN_PEPPER* / AUDIT_PII_SALT  (auth/pii concerns — iam-svc owns)
#   This trimming is the §5.D blast-radius win: a compromised svc-export pod cannot
#   read the Gemini key, the SMS key, or the Razorpay secret.
#
# ── DATABASE_URL — schema-scoped (MASTER_PLAN §2.D / §2.E) ───────────────────
#   Role = export_user (created by schema-role.sql, I5). search_path pins `export`
#   first then `public` (so the app sees its own tables AND public.audit_events).
#   asyncpg passes server options via the URL `options` query param, URL-encoded:
#     ?options=-csearch_path%3Dexport,public
#   (`-c` flag, `%3D` = '='. asyncpg/SQLAlchemy honor this at connect.)
#   Host = postgres.dev.svc.cluster.local:5432 (the shared StatefulSet — V1.5
#   shares one Postgres; PgBouncer/MS-DB-4 NOT in Sub-Plan A).
#   Password = the export_user password set out-of-band from SM (see I5) — the
#   SAME value used in ALTER ROLE export_user WITH PASSWORD. URL-encode any
#   +,/,@ in the password with urllib.parse.quote(pw, safe='') (MEMORY 2026-06-09
#   Redis/PG URL-parsing lesson).
#
# ── VALKEY_URL (shared Valkey; per-service key prefix in app code) ──────────
#   Broker/result DBs per infra plan §4.2 (export queue maps to a dedicated DB in
#   the target; for Sub-Plan A dev it uses the existing broker DB 1 / result DB 2
#   that the monolith worker uses — export.xlsx is on the default `celery` queue).
#   Keys gain a `svc-export:` prefix in app code (MASTER_PLAN §2.E) — infra side is
#   just the URL.
#
# Populate from GCP Secret Manager (project=project-1f5cbf72-2820-4cdb-949):
#   JWT_SECRET            ← SM `jwt-secret`            (gcloud secrets versions access latest --secret=jwt-secret)
#   export_user password  ← SM `dev-export-db-password` (NEW SM secret — founder to
#                            create at bootstrap; SAME value used in I5 ALTER ROLE)
#                            ⚠ INTER-LEAD: this is the one new SM secret Sub-Plan A
#                            needs. It is a per-service DB password, NOT a new IAM
#                            grant — within the §4 ceiling. Founder creates the SM
#                            container + version; infra composes it into DATABASE_URL.
# ===========================================================================
apiVersion: v1
kind: Secret
metadata:
  name: svc-export-secrets
  namespace: dev
type: Opaque
stringData:
  # --- Database (schema-scoped to `export`, role export_user) ---
  DATABASE_URL: "postgresql+asyncpg://export_user:REPLACE-ME@postgres.dev.svc.cluster.local:5432/meesell?options=-csearch_path%3Dexport,public"

  # --- Valkey (shared instance; broker DB 1 / result DB 2 in dev; svc-export: key prefix in app) ---
  VALKEY_URL: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/0"
  CELERY_BROKER_URL: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/1"
  CELERY_RESULT_BACKEND: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/2"

  # --- JWT (LOCAL verification per D7/A2; shared HS256 secret from SM jwt-secret) ---
  JWT_SECRET: "REPLACE-ME-FROM-SM-jwt-secret"

  # --- App env (Pydantic Literal: development|staging|production) ---
  # dev namespace ⇒ "development" (MEMORY: NEVER "dev"; the Literal type rejects it).
  APP_ENV: "development"

  # --- GCS (single-bucket SSOT; non-secret values, keyless auth — no key.json) ---
  GCS_BUCKET: "meesell-prod-assets"
  GCS_PROJECT_ID: "project-1f5cbf72-2820-4cdb-949"
  # NO GOOGLE_APPLICATION_CREDENTIALS — keyless via GCE metadata server (I6).

  # --- DELIBERATELY ABSENT (handoff §1 I7): GEMINI_API_KEY, LANGFUSE_SECRET_KEY,
  #     MSG91_AUTH_KEY, MSG91_TEMPLATE_ID, RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET,
  #     RAZORPAY_WEBHOOK_SECRET, REFRESH_TOKEN_PEPPER*, AUDIT_PII_SALT. ---
