# Template only — DO NOT commit a populated copy of this file.
#
# STAGING-namespace application Secret `backend-secrets`. This mirrors the dev
# template at k8s/secrets.yaml.example but targets `namespace: staging`. The
# `staging` namespace's `backend-secrets` k8s Secret is populated at deploy time the
# same way dev was (manual bootstrap from GCP Secret Manager OR external-secrets-
# operator in V1.5). The staging Kustomize overlay (kustomization.yaml) carries ONLY
# the non-secret ConfigMap — secret VALUES never live in git.
#
# ─────────────────────────────────────────────────────────────────────────────
# FOUNDER INJECTION STEP — GEMINI_API_KEY (staging)
# ─────────────────────────────────────────────────────────────────────────────
# The image-precheck watermark workload (and all Gemini calls) need a real
# GEMINI_API_KEY in the STAGING namespace before the staging soak gates (D2 Gate 1,
# watermark ≥85%) can run. This is the ONLY infra-prepped-but-founder-injected secret
# for this slice.
#
# The infra agent does NOT hold the key value and NEVER commits or prints one. The
# founder injects it at staging deploy time. Two supported sources:
#
#   OPTION A (reuse the existing SM secret — recommended for V1):
#     The dev key in Secret Manager (`gemini-api-key`) is the production-quota key.
#     Reuse it for staging:
#       KEY=$(gcloud secrets versions access latest --secret=gemini-api-key \
#               --project=project-1f5cbf72-2820-4cdb-949)
#       kubectl -n staging create secret generic backend-secrets \
#         --from-literal=GEMINI_API_KEY="$KEY" \
#         --from-literal=... (the other keys, per the dev template) \
#         --dry-run=client -o yaml | kubectl apply -f -
#       unset KEY
#
#   OPTION B (a separate staging-scoped key — if isolating staging quota):
#     1. Create a key at https://aistudio.google.com/apikey (cap/quota as desired).
#     2. Store it as a NEW Secret Manager version/secret, e.g. `gemini-api-key-staging`:
#          printf '%s' 'AIza...' | gcloud secrets versions add gemini-api-key-staging \
#            --project=project-1f5cbf72-2820-4cdb-949 --data-file=-
#     3. Source it into the staging `backend-secrets` as GEMINI_API_KEY (same kubectl
#        create-secret pattern as Option A).
#
# NOTE: `secrets.GEMINI_API_KEY_CI` in .github/workflows/ci.yml is a SEPARATE,
# CI-only, low-quota key consumed ONLY by the nightly ai_eval job. It is NOT the
# staging runtime key and is owned by the CI track — do not conflate the two.
# (ci.yml is NOT modified by this slice.)
#
# ─────────────────────────────────────────────────────────────────────────────
# Full staging key set — same shape as k8s/secrets.yaml.example, namespace=staging.
# Every value is REPLACE-ME; the authoritative values come from GCP Secret Manager.
# ─────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: staging
type: Opaque
stringData:
  # --- Database / cache (staging StatefulSet passwords; compose from SM/bootstrap) ---
  POSTGRES_PASSWORD: "REPLACE-ME"
  DATABASE_URL: "postgresql+asyncpg://meesell:REPLACE-ME@postgres.staging.svc.cluster.local:5432/meesell"
  VALKEY_URL: "redis://:REPLACE-ME@valkey.staging.svc.cluster.local:6379/0"
  CELERY_BROKER_URL: "redis://:REPLACE-ME@valkey.staging.svc.cluster.local:6379/1"
  CELERY_RESULT_BACKEND: "redis://:REPLACE-ME@valkey.staging.svc.cluster.local:6379/2"

  # --- Secret Manager refs ---
  GEMINI_API_KEY: "REPLACE-ME"        # SM: gemini-api-key — FOUNDER INJECTION (see header)
  MSG91_AUTH_KEY: "REPLACE-ME"        # SM: msg91-auth-key
  MSG91_TEMPLATE_ID: "REPLACE-ME"     # SM: msg91-template-id
  JWT_SECRET: "REPLACE-ME-WITH-LONG-RANDOM-STRING"  # SM: jwt-secret
  RAZORPAY_KEY_ID: "REPLACE-ME"       # SM: razorpay-key-id
  RAZORPAY_KEY_SECRET: "REPLACE-ME"   # SM: razorpay-key-secret
  AUDIT_PII_SALT: "REPLACE-ME"        # SM: audit-pii-salt
  REFRESH_TOKEN_PEPPER: "REPLACE-ME"  # SM: refresh-token-pepper
  REFRESH_TOKEN_PEPPER_PREVIOUS: ""   # only during dual-pepper grace window
  REFRESH_TOKEN_PEPPER_VERSION: "1"
  RAZORPAY_WEBHOOK_SECRET: "REPLACE-ME"  # SM: razorpay-webhook-secret
  LANGFUSE_SECRET_KEY: "REPLACE-ME"      # SM: langfuse-secret-key

  # --- GCS (non-secret; authoritative copies live in the staging ConfigMap) ---
  GCS_BUCKET: "meesell-prod-assets"
  GCS_BUCKET_IMAGES: "meesell-images"
  GCS_PROJECT_ID: "project-1f5cbf72-2820-4cdb-949"
