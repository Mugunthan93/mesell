# k8s/svc-customer/secrets.yaml.example
# ===========================================================================
# svc-customer — Sub-Plan E (customer extraction), INFRA deliverable I6 (secret half).
#
# TEMPLATE ONLY — DO NOT commit a populated copy (playbook §0; no secret in git).
#
# The svc-customer Secret is named `customer-svc-secrets` in the `dev` namespace.
# The single customer-svc-api Deployment consumes it via
# `envFrom: secretRef: { name: customer-svc-secrets }` (see deployment.yaml).
# The NON-secret half of I6 (APP_ENV + CACHE_VERSION) lives in the ConfigMap
# `customer-svc-config` (configmap.yaml) — never put those here, never put a secret
# in the ConfigMap.
#
# Authority: handoff_msE_infra.md §1 I6 + spec_msE_backend.md:58 "shared/{database,
# config,valkey}.py TRIMMED: DATABASE_URL@customer, VALKEY_URL, JWT_SECRET,
# CACHE_VERSION, APP_ENV; NO GEMINI/LANGFUSE/MSG91/RAZORPAY/GCS" + MASTER_PLAN §5.D.
#
# ── WHAT svc-customer NEEDS (and ONLY this) ─────────────────────────────────
#   - DATABASE_URL — role customer_user; search_path pinned to `customer,public`
#                    (its owned seller_profile table + public.audit_events). See the
#                    search_path note below.
#   - VALKEY_URL   — Valkey DB 3 (customer's cache: required_fields 60s +
#                    super_category_set 3600s; `customer:` key prefix in app —
#                    SUB_PLAN_0E §7 / spec_msE_backend.md:59). Shared Valkey instance.
#   - JWT_SECRET   — LOCAL JWT verification (D7/A2: every service validates JWT
#                    locally via vendored core/auth.py; customer does NOT call
#                    iam-svc per token). Shared HS256 secret from SM `jwt-secret`.
#
# ── WHAT svc-customer MUST NOT RECEIVE (handoff §1 I6 — deterministic CRUD) ───
#   NO GEMINI_API_KEY        (no AI — customer is deterministic CRUD)
#   NO LANGFUSE_SECRET_KEY    (no AI tracing)
#   NO MSG91_AUTH_KEY / MSG91_TEMPLATE_ID  (no SMS/OTP — that's iam-svc)
#   NO RAZORPAY_* / RAZORPAY_WEBHOOK_SECRET (no payment — that's iam-svc/billing)
#   NO GCS_* / GOOGLE_APPLICATION_CREDENTIALS (no storage — customer touches NO GCS
#                            at all; this is the handoff "NO GCS service account"
#                            omission made concrete — see report.)
#   NO REFRESH_TOKEN_PEPPER* / AUDIT_PII_SALT  (auth/pii concerns — iam-svc owns)
#   NO CELERY_BROKER_URL / CELERY_RESULT_BACKEND  (no Celery — customer has no task)
#   This trimming is the §5.D blast-radius win: a compromised customer-svc pod
#   cannot read the Gemini key, the SMS key, the Razorpay secret, OR any GCS creds.
#
# ── DATABASE_URL — search_path pinned to customer,public (OWNS a schema) ─────
#   Role = customer_user (created by schema-role.sql, I5). customer OWNS the
#   `customer` schema (seller_profile moves there via the schema-split migration),
#   so DATABASE_URL pins `?options=-csearch_path%3Dcustomer,public` — its session
#   sees `customer` first (owned table) and `public` (for audit_events). This is the
#   svc-export pattern (search_path pinned), NOT the svc-dashboard pattern (no owned
#   schema → default public). Host = postgres.dev.svc.cluster.local:5432 (the shared
#   StatefulSet — V1 shares one Postgres; PgBouncer is LIVE on dev (MS-0 #181/#192)
#   but customer's tiny query-light pool makes pooling a non-concern — handoff §2/§8).
#   Password = the customer_user password set out-of-band from SM (see I5) — the SAME
#   value used in ALTER ROLE customer_user WITH PASSWORD. URL-encode any +,/,@ in the
#   password with urllib.parse.quote(pw, safe='') (MEMORY 2026-06-09 Redis/PG
#   URL-parsing lesson — base64 passwords break URL parsing raw).
#   NOTE: %3D is the URL-encoding of `=` inside the connection-string options value
#   (asyncpg/psycopg server-settings passthrough). %2C (comma) may also be required
#   by some drivers; the svc-export sibling uses %3D with a literal comma — match it.
#
# ── POOL SIZE (deliverable I8 — customer's pool is TINY) ─────────────────────
#   The pool size lives in the backend lane's vendored shared/database.py (query-
#   light, no worker → smallest pool of any service, handoff §1 I8 / §2). NO
#   per-service max_connections change for Sub-Plan E: max_connections=200 is ALREADY
#   LIVE on dev (MS-0, module.postgres_dev args -c max_connections=200) — confirmed
#   for the backend acceptance item (handoff §5). customer's tiny pool keeps the
#   strangler-window connection sum (monolith + extracted services) well under 200.
#
# Populate from GCP Secret Manager (project=project-1f5cbf72-2820-4cdb-949):
#   JWT_SECRET             ← SM `jwt-secret`  (gcloud secrets versions access latest --secret=jwt-secret)
#   customer_user password ← SM `dev-customer-db-password` (NEW SM secret — founder to
#                            create at bootstrap; SAME value used in the I5 ALTER ROLE)
#                            ⚠ INTER-LEAD: this is the one new SM secret Sub-Plan E
#                            needs. It is a per-service DB password, NOT a new IAM
#                            grant — within the §4 ceiling. Founder creates the SM
#                            container + version; infra composes it into DATABASE_URL.
#                            (Mirrors svc-export's `dev-export-db-password` +
#                            svc-dashboard's `dev-dashboard-db-password`.)
#   VALKEY password        ← the existing dev Valkey password (SM/dev creds, same
#                            value the monolith uses; shared instance), DB index 3.
# ===========================================================================
apiVersion: v1
kind: Secret
metadata:
  name: customer-svc-secrets
  namespace: dev
type: Opaque
stringData:
  # --- Database (role customer_user; search_path pinned customer,public — OWNS schema) ---
  DATABASE_URL: "postgresql+asyncpg://customer_user:REPLACE-ME@postgres.dev.svc.cluster.local:5432/meesell?options=-csearch_path%3Dcustomer,public"

  # --- Valkey (shared instance; DB 3 for customer's cache; customer: key prefix in app) ---
  # NO CELERY_BROKER_URL / CELERY_RESULT_BACKEND — customer has NO Celery (SUB_PLAN_0E §2).
  VALKEY_URL: "redis://:REPLACE-ME@valkey.dev.svc.cluster.local:6379/3"

  # --- JWT (LOCAL verification per D7/A2; shared HS256 secret from SM jwt-secret) ---
  JWT_SECRET: "REPLACE-ME-FROM-SM-jwt-secret"

  # --- DELIBERATELY ABSENT (handoff §1 I6): GEMINI_API_KEY, LANGFUSE_SECRET_KEY,
  #     MSG91_AUTH_KEY, MSG91_TEMPLATE_ID, RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET,
  #     RAZORPAY_WEBHOOK_SECRET, REFRESH_TOKEN_PEPPER*, AUDIT_PII_SALT,
  #     GCS_BUCKET / GCS_PROJECT_ID / GOOGLE_APPLICATION_CREDENTIALS (no GCS),
  #     CELERY_BROKER_URL / CELERY_RESULT_BACKEND (no Celery).
  #     APP_ENV + CACHE_VERSION live in the ConfigMap (customer-svc-config), NOT here
  #     (they are non-secret). ---
