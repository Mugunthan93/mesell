# GCS Service Account Secret — EXAMPLE / REFERENCE
#
# NOTE: The GCP org policy constraints/iam.disableServiceAccountKeyCreation is
# enforced on org 698205129974. SA JSON key files cannot be created.
# This project uses the GCE metadata server for keyless authentication instead.
#
# CURRENT APPROACH (keyless — no Secret needed):
#   Pods on the K3s node inherit the VM-attached SA meesell-workload@... via
#   the metadata server at 169.254.169.254. Do NOT set GOOGLE_APPLICATION_CREDENTIALS.
#   The meesell-workload SA has roles/storage.objectAdmin on gs://meesell-dev.
#
# FUTURE: If the org policy is lifted and you need an explicit key-based Secret:
#   1. Generate the key:
#        gcloud iam service-accounts keys create k8s/meesell-worker-sa-key.json \
#          --iam-account=meesell-worker@project-1f5cbf72-2820-4cdb-949.iam.gserviceaccount.com
#   2. Create the K8s Secret:
#        kubectl create secret generic meesell-gcs-sa \
#          --from-file=key.json=k8s/meesell-worker-sa-key.json \
#          -n meesell
#   3. OR apply the manifest below after base64-encoding the key:
#        base64 -i k8s/meesell-worker-sa-key.json | tr -d '\n'
#
# --- MANIFEST (for future key-based auth, do not apply currently) ---
apiVersion: v1
kind: Secret
metadata:
  name: meesell-gcs-sa
  namespace: meesell
type: Opaque
data:
  key.json: <BASE64_OF_KEY_JSON_HERE>
#
# To mount this Secret in worker.yaml (only when key-based auth is in use):
#
#   spec:
#     template:
#       spec:
#         volumes:
#           - name: gcs-sa-key
#             secret:
#               secretName: meesell-gcs-sa
#         containers:
#           - name: worker
#             ...
#             volumeMounts:
#               - name: gcs-sa-key
#                 mountPath: /var/secrets/google
#                 readOnly: true
#             env:
#               - name: GOOGLE_APPLICATION_CREDENTIALS
#                 value: /var/secrets/google/key.json
