# MeeSell — backend env vars (V1 contract per BACKEND_ARCHITECTURE.md §5.D).
#
# Dev: copy to `.env` at the backend repo root.
# Staging + prod: every secret is injected via GCP Secret Manager → K3s envFrom
# (see meesell-infra-builder memory for Secret Manager IDs).
#
# Fail-fast: shared/config.py SystemExits at boot if any "Required: yes" field
# (per §5.D) is empty.  Provide dev placeholders for all of them — the validator
# does not distinguish dev/staging/prod, only "non-empty".

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://meesell:password@localhost:5433/meesell
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ── Valkey ─────────────────────────────────────────────────────────────────
# DB number in the URL is informational; shared/valkey.py selects the correct
# DB via factory (0=OTP, 1=broker, 2=results, 3=cache).
VALKEY_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ── JWT / Auth (FE-D5 ratified) ────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-string-64-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
# NEW per FE-D5 amendment 2026-06-05.  Secret Manager ref `refresh-token-pepper`
# populated by meesell-infra-builder during the `iam` dispatch.
REFRESH_TOKEN_PEPPER=dev-refresh-pepper-replace-in-prod
# Grace-window rotation (R5): set to the PREVIOUS pepper during the dual-pepper
# window (auth-secret-rotation runbook §2). Leave empty for normal single-pepper
# operation — the dual-read fallback is skipped entirely when this is empty.
REFRESH_TOKEN_PEPPER_PREVIOUS=
# Integer version of the current pepper. Increment by 1 on each rotation.
# Used as the vN segment in the cache:refresh:v{N}:{digest} allowlist key.
REFRESH_TOKEN_PEPPER_VERSION=1
# DEPRECATED — removed during §7 (iam) construction dispatch.
JWT_EXPIRY_DAYS=7

# ── MSG91 ──────────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=dev-msg91-auth-key
MSG91_TEMPLATE_ID=dev-msg91-template-id

# ── Razorpay ───────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=dev-rzp-secret
# NEW.  Populated during `iam` dispatch (webhook signature verify).
RAZORPAY_WEBHOOK_SECRET=dev-rzp-webhook-secret

# ── Gemini ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza_your_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── GCS ────────────────────────────────────────────────────────────────────
GCS_BUCKET=meesell-dev
GCS_PROJECT_ID=your-gcp-project-id
GCS_SIGNED_URL_TTL_SECONDS=3600

# ── LangFuse ───────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=dev-langfuse-public
# NEW.  Populated during §6A ai_ops integration dispatch.
LANGFUSE_SECRET_KEY=dev-langfuse-secret
LANGFUSE_HOST=https://cloud.langfuse.com

# ── AI Ops ─────────────────────────────────────────────────────────────────
AI_DAILY_BUDGET_INR=500
AI_BUDGET_ALARM_THRESHOLD=0.80

# ── Cache ──────────────────────────────────────────────────────────────────
CACHE_VERSION=v1

# ── Audit (PII scrubbing per §4.G) ─────────────────────────────────────────
AUDIT_PII_SALT=dev-audit-salt-replace-in-prod

# ── Rate limits ────────────────────────────────────────────────────────────
RL_PER_IP_PER_MINUTE=120

# ── CORS (§4.G amendment — NEVER '*') ──────────────────────────────────────
# Accept comma-separated values OR JSON array.  Wildcard rejected at boot.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
